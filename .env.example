# Electricity Maps API
ELECTRICITY_MAPS_API_KEY=your_sandbox_api_key_here
ELECTRICITY_MAPS_BASE_URL=https://api.electricitymap.org/v3

# Storage paths (local or s3://bucket/prefix)
DATA_LAKE_ROOT=./data

# Spark settings
SPARK_MASTER=local[*]
SPARK_APP_NAME=electricity-maps-etl

# Optional: AWS credentials for S3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-west-1
